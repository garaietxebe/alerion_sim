{#
  Mundo de inspeccion – Jinja2 template
  Renderizado por simulation.launch.py en carga.

  variables:
    physics_enabled       bool
    physics_gravity_z     float   (0.0 minimal, -9.81 dev full)
    physics_rtf           float   (0.0 = uncapped, 1.0 = real-time)
    physics_step          float
    rendering_enabled     bool    — GUI viewport + renderer active (headless=false)
    scene_enabled         bool    — scene objects included (warehouse, helipad…);
                                    gpu_lidar requires this true to see geometry
    rendering_shadows     bool
    rendering_pbr         bool    (false=flat materials, true=metal/roughness PBR)
    wind_enabled          bool
    wind_vel_x            float
    wind_vel_y            float
    wind_vel_z            float

  Editar el yaml de inspection para hacer cambios
#}
<?xml version="1.0" encoding="UTF-8"?>
<sdf version="1.9">
  <world name="inspection">

    <!-- ================================================================
         GUI layout
         Añadimos todos los plugins requeridos por el GUI con un  bloque <gui>
         Mnimimal ignora el gui
    ================================================================ -->
    {%- if rendering_enabled %}
    
    <gui fullscreen="0">

      <!-- ── 3D viewport ─────────────────────────────────────────── -->
      <plugin filename="MinimalScene" name="3D View">
        <gz-gui>
          <title>3D View</title>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <engine>ogre2</engine>
        <scene>scene</scene>
        <ambient_light>0.4 0.4 0.4</ambient_light>
        <background_color>0.7 0.7 0.7</background_color>
        <camera_pose>-8 0 5 0 0.4 0</camera_pose>
      </plugin>

      <!-- ── Headless scene helpers (5×5 px invisible) ─────────── -->
      <plugin filename="GzSceneManager" name="Scene Manager">
        <gz-gui>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="bool"   key="resizable">false</property>
          <property type="double" key="width">5</property>
          <property type="double" key="height">5</property>
          <property type="string" key="state">floating</property>
        </gz-gui>
      </plugin>
      <plugin filename="InteractiveViewControl" name="Interactive view control">
        <gz-gui>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="bool"   key="resizable">false</property>
          <property type="double" key="width">5</property>
          <property type="double" key="height">5</property>
          <property type="string" key="state">floating</property>
        </gz-gui>
      </plugin>
      <plugin filename="CameraTracking" name="Camera Tracking">
        <gz-gui>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="bool"   key="resizable">false</property>
          <property type="double" key="width">5</property>
          <property type="double" key="height">5</property>
          <property type="string" key="state">floating</property>
        </gz-gui>
      </plugin>
      <plugin filename="SelectEntities" name="Select Entities">
        <gz-gui>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="bool"   key="resizable">false</property>
          <property type="double" key="width">5</property>
          <property type="double" key="height">5</property>
          <property type="string" key="state">floating</property>
        </gz-gui>
      </plugin>
      <plugin filename="EntityContextMenuPlugin" name="Entity context menu">
        <gz-gui>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="bool"   key="resizable">false</property>
          <property type="double" key="width">5</property>
          <property type="double" key="height">5</property>
          <property type="string" key="state">floating</property>
        </gz-gui>
      </plugin>
      <plugin filename="MarkerManager" name="Marker manager">
        <gz-gui>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="bool"   key="resizable">false</property>
          <property type="double" key="width">5</property>
          <property type="double" key="height">5</property>
          <property type="string" key="state">floating</property>
        </gz-gui>
      </plugin>
      <plugin filename="Spawn" name="Spawn Entities">
        <gz-gui>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="bool"   key="resizable">false</property>
          <property type="double" key="width">5</property>
          <property type="double" key="height">5</property>
          <property type="string" key="state">floating</property>
        </gz-gui>
      </plugin>
      <plugin filename="VisualizationCapabilities" name="Visualization Capabilities">
        <gz-gui>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="bool"   key="resizable">false</property>
          <property type="double" key="width">5</property>
          <property type="double" key="height">5</property>
          <property type="string" key="state">floating</property>
        </gz-gui>
      </plugin>

      

      <!-- ── Bottom-left: play/pause/step ──────────────────────── -->
      <plugin filename="WorldControl" name="World control">
        <gz-gui>
          <title>World control</title>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="bool"   key="resizable">false</property>
          <property type="double" key="height">100</property>
          <property type="double" key="width">150</property>
          <property type="double" key="z">1</property>
          <property type="string" key="state">floating</property>
          <anchors target="3D View">
            <line own="left"   target="left"/>
            <line own="bottom" target="bottom"/>
          </anchors>
        </gz-gui>
        <play_pause>true</play_pause>
        <step>true</step>
        <start_paused>false</start_paused>
      </plugin>

      <!-- ── Bottom-right: sim time / RTF stats ────────────────── -->
      <plugin filename="WorldStats" name="World stats">
        <gz-gui>
          <title>World stats</title>
          <property type="bool"   key="showTitleBar">false</property>
          <property type="bool"   key="resizable">false</property>
          <property type="double" key="height">110</property>
          <property type="double" key="width">290</property>
          <property type="double" key="z">1</property>
          <property type="string" key="state">floating</property>
          <anchors target="3D View">
            <line own="right"  target="right"/>
            <line own="bottom" target="bottom"/>
          </anchors>
        </gz-gui>
        <sim_time>true</sim_time>
        <real_time>true</real_time>
        <real_time_factor>true</real_time_factor>
        <iterations>true</iterations>
      </plugin>

      


      <plugin filename="ImageDisplay" name="Camera Feed">
        <gz-gui>
          <title>Camera Feed</title>
          <property type="bool"   key="showTitleBar">true</property>
          <property type="string" key="state">floating</property>
          <property type="double" key="x">0</property>
          <property type="double" key="y">0</property>
          <property type="double" key="z">2</property>
          <property type="double" key="width">400</property>
          <property type="double" key="height">400</property>
        </gz-gui>
        <topic>/camera/image_raw</topic>
        <topic_picker>false</topic_picker>
      </plugin>

    </gui>
    {%- endif %}

    <!-- 
         System plugins
         Todas las fisicas sensore y plugins de puentes estan cargados por PX4 server config
     -->

    <!-- Fisicas -->
    <physics type="ode">
      <max_step_size>{{ physics_step }}</max_step_size>
      {%- if physics_enabled %}
      <real_time_factor>{{ physics_rtf }}</real_time_factor>
      <real_time_update_rate>{{ (1.0 / physics_step) | int }}</real_time_update_rate>
      {%- else %}
      <!-- minimal level: velocidad max sin gravedad para este nivel -->
      <real_time_factor>0</real_time_factor>
      <real_time_update_rate>0</real_time_update_rate>
      {%- endif %}
    </physics>

    <gravity>0 0 {{ physics_gravity_z }}</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>

    <!-- 
         Viento (con full solo)
     -->
    {%- if wind_enabled %}
    <wind>
      <linear_velocity>{{ wind_vel_x }} {{ wind_vel_y }} {{ wind_vel_z }}</linear_velocity>
    </wind>
    {%- endif %}

    <!-- entorno -->
    <scene>
      <grid>false</grid>
      <ambient>{{ '0.3 0.3 0.3 1' if rendering_pbr else '0.4 0.4 0.4 1' }}</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>{{ 'true' if rendering_enabled and rendering_shadows else 'false' }}</shadows>
    </scene>

    <!-- 
         Sol direccional
     -->
    <light name="sunUTC" type="directional">
      <pose>0 0 500 0 0 0</pose>
      <cast_shadows>{{ 'true' if rendering_enabled and rendering_shadows else 'false' }}</cast_shadows>
      <intensity>1</intensity>
      <direction>0.001 0.625 -0.78</direction>
      <diffuse>0.904 0.904 0.904 1</diffuse>
      <specular>{{ '0.6 0.6 0.6 1' if rendering_pbr else '0.271 0.271 0.271 1' }}</specular>
      <attenuation>
        <range>2000</range>
        <linear>0</linear>
        <constant>1</constant>
        <quadratic>0</quadratic>
      </attenuation>
    </light>

    {%- if rendering_pbr %}
    <light name="fill_north" type="directional">
      <pose>0 0 200 0 0 0</pose>
      <cast_shadows>false</cast_shadows>
      <intensity>0.35</intensity>
      <direction>-0.2 -0.5 -0.84</direction>
      <diffuse>0.55 0.60 0.70 1</diffuse>
      <specular>0.05 0.05 0.05 1</specular>
    </light>
    {%- endif %}

    <!-- plano base -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>500 500</size>
            </plane>
          </geometry>
          <surface>
            <friction><ode/></friction>
            <bounce/>
            <contact/>
          </surface>
        </collision>
        {%- if scene_enabled %}
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>500 500</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
        {%- endif %}
        <enable_wind>false</enable_wind>
      </link>
    </model>


