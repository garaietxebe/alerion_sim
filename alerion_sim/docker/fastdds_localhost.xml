<?xml version="1.0" encoding="UTF-8" ?>
<!--
  FastDDS profile — localhost-only unicast
  =========================================
  Forces DDS discovery and data traffic through the loopback interface only
  (127.0.0.1). This is required when running multiple containers with
  network_mode: host on the same machine — multicast discovery on loopback
  is unreliable with FastDDS and causes topics published in one container
  (e.g. sim) to be invisible to subscribers in another (e.g. validate).

  Referenced via FASTRTPS_DEFAULT_PROFILES_FILE in docker-compose.yml.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

    <transport_descriptors>
        <transport_descriptor>
            <transport_id>udpv4_localhost</transport_id>
            <type>UDPv4</type>
            <interfaceWhiteList>
                <address>127.0.0.1</address>
            </interfaceWhiteList>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="default_profile" is_default_profile="true">
        <rtps>
            <userTransports>
                <transport_id>udpv4_localhost</transport_id>
            </userTransports>
            <useBuiltinTransports>false</useBuiltinTransports>
        </rtps>
    </participant>

</profiles>
